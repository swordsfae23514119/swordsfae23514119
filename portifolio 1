algoritmo "Lanchonete"

var
   codigo: inteiro

inicio

   escreval("1 - Cachorro Quente (R$ 8,00)")
   escreval("2 - Hambúrguer (R$ 15,00)")
   escreval("3 - Misto Quente (R$ 10,00)")
   escreval("4 - Refrigerante (R$ 5,00)")
   escreva("Digite o código do item: ")
   leia(codigo)

   escolha codigo

      caso 1
         escreval("Cachorro Quente - R$ 8,00")

      caso 2
         escreval("Hambúrguer - R$ 15,00")

      caso 3
         escreval("Misto Quente - R$ 10,00")

      caso 4
         escreval("Refrigerante - R$ 5,00")

      outrocaso
         escreval("Código inválido!")

   fimescolha

fimalgoritmo
algoritmo "TelaBloqueio"

var
   senha: caractere
   senhaCorreta: caractere

inicio

   senhaCorreta <- "123456"

   escreva("Digite a senha: ")
   leia(senha)

   enquanto (senha <> senhaCorreta) faca
      limpatela
      escreval("Senha incorreta, acesso negado. Tente novamente:")
      escreva("Digite a senha: ")
      leia(senha)
   fimenquanto

   escreval("Acesso liberado!")

fimalgoritmo
algoritmo "CaixaEletronico"

var
   opcao: inteiro
   saldo, valor: real

inicio

   saldo <- 1000.00
   opcao <- -1

   enquanto (opcao <> 0) faca

      escreval("1 - Consultar Saldo")
      escreval("2 - Fazer Saque")
      escreval("3 - Fazer Depósito")
      escreval("0 - Sair")
      escreva("Escolha uma opção: ")
      leia(opcao)

      escolha opcao

         caso 1
            escreval("Saldo: R$ ", saldo)

         caso 2
            escreva("Valor do saque: R$ ")
            leia(valor)

            se (valor <= saldo) entao
               saldo <- saldo - valor
               escreval("Novo saldo: R$ ", saldo)
            senao
               escreval("Saldo insuficiente!")
            fimse

         caso 3
            escreva("Valor do depósito: R$ ")
            leia(valor)

            saldo <- saldo + valor
            escreval("Novo saldo: R$ ", saldo)

         caso 0
            escreval("Sistema encerrado.")

         outrocaso
            escreval("Opção inválida!")

      fimescolha

   fimenquanto

fimalgoritmo
